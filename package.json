{
  "name": "chinese-travel-map",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "Chinese Travel Map — interactive bilingual (Thai/English) Western China sales route map — MapLibre GL + road-snapped routes for Thai outbound travel agents.",
  "scripts": {
    "dev": "vite",
    "build": "npm run scaffold:media && tsc --noEmit && vite build",
    "build:routes": "tsx scripts/build-routes.ts",
    "build:dayroutes": "tsx scripts/build-day-routes.ts",
    "build:images": "tsx scripts/build-images.ts",
    "build:weather": "tsx scripts/build-weather.ts",
    "build:hotels": "tsx scripts/build-hotels.ts",
    "build:rednote": "tsx scripts/build-rednote.ts",
    "audit:attractions": "tsx scripts/audit-attractions.ts",
    "scaffold:media": "tsx scripts/build-media-manifest.ts",
    "audit:media": "tsx scripts/audit-media.ts",
    "geo": "tsx scripts/geo-lookup.ts",
    "autolink:stops": "tsx scripts/autolink-stops.ts",
    "build:data": "npm run build:routes && npm run build:dayroutes && npm run build:images && npm run build:weather && npm run build:hotels && npm run build:rednote",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@turf/turf": "^7.1.0",
    "i18next": "^23.16.8",
    "lucide-react": "^0.456.0",
    "maplibre-gl": "^4.7.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.1.3",
    "react-map-gl": "^7.1.7"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.14",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.14",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
